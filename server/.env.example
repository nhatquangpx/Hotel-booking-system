# Sao chép file này thành .env và điền giá trị thật (không commit .env lên git)
# cp .env.example .env

# --- Server ---
PORT=8001
NODE_ENV=development

# URL frontend (CORS + cookie + redirect VNPay). Không có dấu / ở cuối.
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# --- Database ---
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# --- Auth (JWT trong cookie HttpOnly) ---
JWT_SECRET=your-strong-random-secret-min-32-chars
# Access token ngắn (API); refresh token dài (cookie riêng, path /api/auth)
JWT_ACCESS_EXPIRES=15m
# Số nguyên (ngày), ví dụ 7 — không dùng "7d"
JWT_REFRESH_DAYS=7

# --- Cloudinary (upload ảnh) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Email (Gmail App Password hoặc SMTP) ---
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# --- Thanh toán QR mặc định (chuyển khoản) ---
DEFAULT_QR_ACCOUNT_NAME=Ten chu tai khoan
DEFAULT_QR_ACCOUNT_NUMBER=1234567890
DEFAULT_QR_BANK_NAME=Vietcombank
# Tùy chọn: đường dẫn ảnh QR tĩnh
# DEFAULT_QR_IMAGE_URL=/assets/qr-code.png

# --- VNPay (sandbox / production) ---
VNPAY_HOST=https://sandbox.vnpayment.vn
VNPAY_TMN_CODE=your_tmn_code
VNPAY_SECURE_SECRET=your_secure_secret
# URL server nhận callback từ VNPay (phải trỏ tới API backend)
VNPAY_RETURN_URL=http://localhost:8001/api/payment/vnpay-return
# VNPAY_TEST_MODE=false

# --- Tùy chọn ---
# BACKEND_URL=http://localhost:8001
# API_URL=http://localhost:8001
