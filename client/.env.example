# Sao chép file này thành .env và điền giá trị thật (không commit .env lên git)
# cp .env.example .env

# Base URL API (có /api ở cuối). Axios + cookie withCredentials dùng biến này.
# Local:
VITE_API_URL=http://localhost:8001/api

# Production (ví dụ Railway):
# VITE_API_URL=https://your-backend.up.railway.app/api

# Lưu ý deploy cookie:
# - Server: FRONTEND_URL = đúng origin frontend (https://...)
# - Server: NODE_ENV=production trên môi trường production
# - Client và server đều dùng HTTPS khi khác domain
